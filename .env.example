# Server port -- the Express + Socket.io server will listen here.
PORT=3000

# MongoDB connection string. When running locally (without Docker) you
# typically point this at localhost. Inside Docker Compose the hostname
# is the service name defined in docker-compose.yml (i.e. "mongo").
MONGODB_URI=mongodb://localhost:27017/livechat

# Set to "production" to disable verbose logging and development helpers.
NODE_ENV=development
